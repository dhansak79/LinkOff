#!/bin/sh
SWAMP="${HOME}/.swamp/bin/swamp"
command -v swamp >/dev/null 2>&1 && SWAMP="swamp"

# Determine the diff base without relying on stdin (which is absent in
# non-interactive environments such as Claude Code / CI scripts).
# Prefer the upstream tracking branch; fall back to merge-base with origin/main.
upstream=$(git rev-parse --abbrev-ref "@{u}" 2>/dev/null)
if [ -n "$upstream" ]; then
  base=$(git rev-parse "$upstream" 2>/dev/null)
else
  base=$(git merge-base HEAD origin/main 2>/dev/null)
fi

if [ -n "$base" ]; then
  files=$(git diff --name-only "$base"..HEAD 2>/dev/null)
else
  files=$(git log --name-only --pretty=format: HEAD 2>/dev/null | grep '.')
fi

# Run quality-gate unless every changed file is under telemetry/.
# Note: avoid grep -qv (BSD grep quirk — -q and -v interact unexpectedly).
if [ -z "$files" ] || echo "$files" | grep -v '^telemetry/' | grep -q .; then
  "$SWAMP" workflow run quality-gate
fi

# Final sync after workflow completes — captures the current run's own YAML
node scripts/sync-telemetry.js && git add telemetry/ && git diff --cached --quiet || git commit -m "telemetry: sync"
