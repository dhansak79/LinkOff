#!/bin/sh
SWAMP="${HOME}/.swamp/bin/swamp"
command -v swamp >/dev/null 2>&1 && SWAMP="swamp"

# Skip if all pushed changes are in telemetry/
run_check=0
while read local_ref local_sha remote_ref remote_sha; do
  zero="0000000000000000000000000000000000000000"
  if [ "$remote_sha" = "$zero" ]; then
    files=$(git log --name-only --pretty=format: "$local_sha" --not --remotes 2>/dev/null | grep '.')
  else
    files=$(git diff --name-only "${remote_sha}..${local_sha}" 2>/dev/null)
  fi
  if [ -n "$files" ] && echo "$files" | grep -qv '^telemetry/'; then
    run_check=1
    break
  fi
done

if [ "$run_check" -eq 1 ]; then
  "$SWAMP" workflow run quality-gate
fi

# Final sync after workflow completes — captures the current run's own YAML
node scripts/sync-telemetry.js && git add telemetry/ && git diff --cached --quiet || git commit -m "telemetry: sync"
