{
  "root": true,
  "env": {
    "es6": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "globals": {
    "chrome": true,
    "Tagify": true
  },
  "plugins": ["prettier", "import"],
  "extends": ["eslint:recommended", "prettier"],
  "rules": {
    "import/no-unresolved": ["error", { "ignore": ["^node:", "^vitest", "^@vitest"] }]
  },
  "overrides": [
    {
      "files": ["tests/cucumber/**/*.js", "scripts/**/*.js"],
      "env": {
        "browser": false,
        "node": true
      },
      "rules": {
        "import/named": "error"
      }
    },
    {
      "files": ["tests/**/*.js"],
      "env": {
        "node": true
      }
    }
  ]
}
